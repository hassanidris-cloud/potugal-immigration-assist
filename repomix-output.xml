/* Why Portugal */
.why-portugal {
  padding: 4rem 0;
  background: linear-gradient(to bottom, #ffffff 0%, #f8fafc 100%);
}

.why-portugal-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
  gap: 1.5rem;
}

.why-portugal-card {
  background: white;
  padding: 1.5rem;
  border-radius: 12px;
  box-shadow: 0 2px 12px rgba(0, 0, 0, 0.06);
  border: 1px solid var(--border);
  transition: transform 0.2s, box-shadow 0.2s;
}

.why-portugal-card:hover {
  transform: translateY(-4px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
}

.why-portugal-icon {
  font-size: 2rem;
  display: block;
  margin-bottom: 0.75rem;
}

/* Why Portugal – four theme blocks (image + copy) */
.why-portugal-blocks {
  display: flex;
  flex-direction: column;
  gap: 3rem;
}

.why-portugal-block {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2rem;
  align-items: center;
  min-height: 280px;
}

.why-portugal-block-reverse {
  direction: rtl;
}

.why-portugal-block-reverse > * {
  direction: ltr;
}

.why-portugal-block-image {
  width: 100%;
  height: 100%;
  min-height: 260px;
  border-radius: 12px;
  background-size: cover;
  background-position: center;
  position: relative;
  overflow: hidden;
}

.why-portugal-block-image img {
  position: absolute;
  inset: 0;
  width: 100%;
  height: 100%;
  object-fit: cover;
  border-radius: 12px;
