    try {
      const { status, admin_notes, reviewed_by } = req.body

      const updateData: any = {}
      if (status) updateData.status = status
      if (admin_notes !== undefined) updateData.admin_notes = admin_notes
      if (reviewed_by) {
        updateData.reviewed_by = reviewed_by
