/* Site-wide fade-in on scroll: add class "fade-in-on-scroll" and data-fade-in to section content */
.fade-in-on-scroll {
  opacity: 0;
  transform: translateY(28px);
  transition: opacity 0.65s cubic-bezier(0.22, 1, 0.36, 1), transform 0.65s cubic-bezier(0.22, 1, 0.36, 1);
}
.fade-in-on-scroll.fade-in-visible {
  opacity: 1;
  transform: translateY(0);
}

/* Reveal on scroll: content fades and slides up when in viewport */
.reveal-on-scroll {
  opacity: 0;
  transform: translateY(32px);
  transition: opacity 0.7s cubic-bezier(0.22, 1, 0.36, 1), transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
}
.reveal-on-scroll.reveal-visible {
  opacity: 1;
  transform: translateY(0);
}
.reveal-on-scroll .reveal-stagger-item {
  opacity: 0;
  transform: translateY(20px);
  transition: opacity 0.5s cubic-bezier(0.22, 1, 0.36, 1), transform 0.5s cubic-bezier(0.22, 1, 0.36, 1);
}
.reveal-on-scroll.reveal-visible .reveal-stagger-item { opacity: 1; transform: translateY(0); }
.reveal-on-scroll.reveal-visible .reveal-stagger-item:nth-child(1) { transition-delay: 0.05s; }
.reveal-on-scroll.reveal-visible .reveal-stagger-item:nth-child(2) { transition-delay: 0.12s; }
.reveal-on-scroll.reveal-visible .reveal-stagger-item:nth-child(3) { transition-delay: 0.19s; }
.reveal-on-scroll.reveal-visible .reveal-stagger-item:nth-child(4) { transition-delay: 0.26s; }
.reveal-on-scroll.reveal-visible .reveal-stagger-item:nth-child(5) { transition-delay: 0.33s; }
.reveal-on-scroll.reveal-visible .reveal-stagger-item:nth-child(6) { transition-delay: 0.4s; }

.hero-slideshow-dots {
  position: absolute;
  bottom: 2rem;
  left: 50%;
  transform: translateX(-50%);
  display: flex;
  gap: 0.75rem;
  z-index: 2;
}

.hero-slideshow-dots button {
  width: 12px;
  height: 12px;
  border-radius: 50%;
  border: 2px solid rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.3);
  cursor: pointer;
  transition: background 0.3s, transform 0.2s;
  padding: 0;
}

.hero-slideshow-dots button:hover {
  background: rgba(255, 255, 255, 0.6);
  transform: scale(1.15);
}

.hero-slideshow-dots button.active {
  background: white;
  transform: scale(1.2);
}

.hero-slideshow-arrows {
  position: absolute;
  top: 50%;
  transform: translateY(-50%);
  width: 100%;
  display: flex;
  justify-content: space-between;
  padding: 0 1rem;
  pointer-events: none;
  z-index: 2;
}

.hero-slideshow-arrows button {
  pointer-events: auto;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: 2px solid rgba(255, 255, 255, 0.8);
  background: rgba(0, 0, 0, 0.25);
  color: white;
  font-size: 1.5rem;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: background 0.2s, transform 0.2s;
  padding: 0;
  line-height: 1;
}

.hero-slideshow-arrows button:hover {
  background: rgba(0, 0, 0, 0.45);
  transform: scale(1.08);
}

