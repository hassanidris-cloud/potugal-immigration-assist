/* Back to top — fixed on the side, appears after scroll */
.back-to-top {
  position: fixed;
  right: 1.25rem;
  bottom: 5rem;
  z-index: 90;
  width: 48px;
  height: 48px;
  border-radius: 50%;
  border: none;
  background: var(--primary);
  color: white;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 4px 16px rgba(0, 0, 0, 0.2);
  opacity: 0;
  visibility: hidden;
  transform: translateY(8px);
  transition: opacity 0.25s ease, visibility 0.25s ease, transform 0.25s ease, background 0.2s ease;
}

.back-to-top.visible {
  opacity: 1;
  visibility: visible;
  transform: translateY(0);
}

.back-to-top:hover {
  background: var(--nav-bg);
  color: white;
}

.back-to-top:focus {
  outline: 2px solid var(--accent);
  outline-offset: 2px;
}

@media (max-width: 639px) {
  .back-to-top {
    left: max(1rem, env(safe-area-inset-left, 0px) + 0.5rem);
    right: auto;
    bottom: 5.5rem;
    width: 48px;
    height: 48px;
    min-width: 48px;
    min-height: 48px;
    -webkit-tap-highlight-color: transparent;
  }
}

