/* Sticky CTA bar — flush bottom, safe-area for notched phones */
.sticky-cta-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background: var(--nav-bg);
  color: #fff;
  padding: 0.75rem 1.25rem;
  padding-bottom: max(0.75rem, env(safe-area-inset-bottom, 0px) + 0.5rem);
  padding-left: max(1.25rem, env(safe-area-inset-left, 0px) + 0.5rem);
  padding-right: max(1.25rem, env(safe-area-inset-right, 0px) + 0.5rem);
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 0.75rem;
  flex-wrap: wrap;
  z-index: 99;
  box-shadow: 0 -2px 12px rgba(0, 0, 0, 0.15);
  border-top: 1px solid rgba(255, 255, 255, 0.1);
  transform: translateY(100%);
  transition: transform 0.25s ease;
}

.sticky-cta-bar.visible {
  transform: translateY(0);
}

/* Reserve space above sticky CTA so footer and last section stay visible when bar is shown */
.home-content-layer:has(.sticky-cta-bar) {
  padding-bottom: 5.5rem;
}

.sticky-cta-bar span {
  color: rgba(255, 255, 255, 0.9);
  font-size: 0.9rem;
}

.sticky-cta-bar a {
  color: #fff;
  font-weight: 600;
  text-decoration: none;
  white-space: nowrap;
  font-size: 0.95rem;
}

.sticky-cta-bar a:hover {
  color: rgba(255, 255, 255, 0.95);
  text-decoration: underline;
}

