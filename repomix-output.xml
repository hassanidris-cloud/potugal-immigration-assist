  if (req.method === 'GET') {
    try {
      const { data, error } = await supabase
        .from('documents')
        .select('*')
        .eq('id', id)
        .single()

      if (error) throw error

      res.status(200).json({ document: data })
    } catch (error: any) {
      res.status(500).json({ error: error.message })
    }
