/* ========== How It Works (legacy / other pages) — timeline + 3D steps ========== */
.how-it-works-section {
  position: relative;
  overflow: hidden;
}

.how-it-works-section::before {
  content: '';
  position: absolute;
  inset: 0;
  background: linear-gradient(180deg, var(--secondary) 0%, var(--border) 100%);
  pointer-events: none;
}

.how-it-works-timeline {
  position: relative;
  max-width: 720px;
  margin: 0 auto;
}

.how-step-card {
  position: relative;
  display: flex;
  gap: 1.5rem;
  align-items: flex-start;
  margin-bottom: 2rem;
  transform-style: preserve-3d;
  will-change: transform;
  transition: transform 0.25s ease-out;
}

.how-step-card:last-child {
  margin-bottom: 0;
}

.how-step-card.how-step-visible {
  animation: howStepIn 0.55s cubic-bezier(0.22, 1, 0.36, 1) forwards;
}

.how-step-card.how-step-visible:nth-child(1) { animation-delay: 0ms; }
.how-step-card.how-step-visible:nth-child(2) { animation-delay: 80ms; }
.how-step-card.how-step-visible:nth-child(3) { animation-delay: 160ms; }
.how-step-card.how-step-visible:nth-child(4) { animation-delay: 240ms; }

.how-step-num {
  width: 56px;
  height: 56px;
  border-radius: 50%;
  background: var(--primary);
  color: #fff;
  font-size: 1.35rem;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
  transition: transform 0.25s ease, box-shadow 0.25s ease;
}

.how-step-card:hover .how-step-num {
  transform: scale(1.08);
  box-shadow: 0 8px 24px rgba(37, 99, 235, 0.3);
}

.how-step-content {
  flex: 1;
  padding: 1.25rem 1.5rem;
  background: rgba(255, 255, 255, 0.95);
  backdrop-filter: blur(8px);
  border-radius: var(--radius-md);
  border: 1px solid var(--border);
  box-shadow: 0 4px 20px rgba(0, 0, 0, 0.06);
  transition: box-shadow 0.25s ease, transform 0.25s ease;
}

.how-step-card:hover .how-step-content {
  box-shadow: 0 10px 28px rgba(0, 0, 0, 0.08);
  transform: translateX(4px);
}

.how-step-content h3 {
  color: var(--text);
  font-size: 1.2rem;
  margin: 0 0 0.5rem 0;
}

.how-step-content h3 a {
  color: inherit;
  text-decoration: none;
}

.how-step-content h3 a:hover {
  text-decoration: underline;
}

/* CTA link: force white text so it’s visible on dark button (h3 a would inherit dark text) */
.how-step-content h3 a.how-step-cta-link,
.how-step-cta-link {
  color: #fff !important;
}

.how-step-cta-link {
  display: inline-block;
  background: var(--primary);
  padding: 0.75rem 1.25rem;
  border-radius: 8px;
  font-weight: 700;
  text-decoration: none;
  margin-bottom: 0.5rem;
  box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
  transition: transform 0.2s ease, box-shadow 0.2s ease, background 0.2s;
}

.how-step-cta-link:hover {
  background: var(--primary-dark);
  transform: translateY(-2px);
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.08);
}

.how-step-content p {
  color: var(--text-muted);
  font-size: 1rem;
  line-height: 1.6;
  margin: 0;
}

.how-step-connector {
  position: absolute;
  left: 27px;
  top: 56px;
  bottom: -2rem;
  width: 2px;
  background: linear-gradient(180deg, rgba(37, 99, 235, 0.35), rgba(37, 99, 235, 0.12));
  border-radius: 1px;
}

.how-step-card:last-child .how-step-connector {
  display: none;
}

@media (max-width: 639px) {
  .how-it-works-timeline {
    padding: 0 0.5rem;
  }

  .how-step-card {
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .how-step-connector {
    left: 50%;
    margin-left: -1px;
    top: 48px;
    bottom: -2rem;
  }

  .how-step-content {
    width: 100%;
    padding: 1rem 1.25rem;
  }

  .how-step-content h3 {
    font-size: 1.1rem;
  }

  .how-step-num {
    width: 48px;
    height: 48px;
    font-size: 1.2rem;
  }

  .how-step-cta-link {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.875rem 1.25rem;
  }
}

@media (min-width: 768px) and (max-width: 1023px) {
  .how-step-card {
    gap: 1.25rem;
  }

  .how-step-content {
    padding: 1.25rem 1.5rem;
  }
}

@keyframes howStepIn {
  from {
    opacity: 0;
    transform: translateY(20px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

