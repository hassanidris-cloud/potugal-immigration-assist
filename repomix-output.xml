}

/* ========== Message your specialist (FAB + panel; reuses shared panel styles) ========== */
.ai-chat-fab {
  display: flex;
  align-items: center;
  gap: 0.5rem;
  padding: 0.75rem 1.25rem;
  min-height: 48px;
  background: linear-gradient(135deg, var(--primary) 0%, var(--logo-green) 100%);
  color: white;
  border: none;
  border-radius: var(--radius-lg);
  font-weight: 600;
  font-size: 0.95rem;
  cursor: pointer;
  box-shadow: 0 4px 20px rgba(37, 99, 235, 0.3);
  transition: transform 0.2s ease, box-shadow 0.2s ease;
  -webkit-tap-highlight-color: transparent;
}

.ai-chat-fab:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 28px rgba(37, 99, 235, 0.35);
}

.ai-chat-fab:focus {
  outline: 2px solid var(--secondary);
  outline-offset: 2px;
}

.ai-chat-fab-icon {
  display: flex;
  align-items: center;
  justify-content: center;
}

.ai-chat-panel {
  position: absolute;
  bottom: calc(100% + 0.75rem);
  right: 0;
  width: 380px;
  max-width: calc(100vw - 2rem);
  max-height: 75vh;
  background: white;
  border-radius: var(--radius-lg);
  box-shadow: 0 20px 60px rgba(0, 0, 0, 0.15);
  border: 1px solid var(--border);
  display: flex;
  flex-direction: column;
  overflow: hidden;
}

.ai-chat-header {
  padding: 1rem 1.25rem;
  background: linear-gradient(135deg, var(--primary) 0%, var(--primary-light) 100%);
  color: white;
  display: flex;
  align-items: center;
  justify-content: space-between;
  flex-shrink: 0;
}

.ai-chat-title {
  font-weight: 600;
  font-size: 1rem;
}

.ai-chat-close {
  background: none;
  border: none;
  color: rgba(255, 255, 255, 0.9);
  font-size: 1.5rem;
  line-height: 1;
  cursor: pointer;
  padding: 0 0.25rem;
  min-width: 44px;
  min-height: 44px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  border-radius: 8px;
  -webkit-tap-highlight-color: transparent;
}

.ai-chat-close:hover {
  background: rgba(255, 255, 255, 0.15);
}

.case-chat-widget {
  position: fixed;
  bottom: 1.25rem;
  right: 1.25rem;
  z-index: 1001;
  font-family: var(--font-sans);
}

.case-chat-panel-body {
  flex: 1;
  overflow: hidden;
  display: flex;
  flex-direction: column;
  min-height: 260px;
  max-height: 360px;
}

/* Typing indicator dots in case chat */
.case-chat-typing-dots {
  display: inline-flex;
  gap: 4px;
  align-items: center;
  margin-right: 0.35rem;
  vertical-align: middle;
}

.case-chat-typing-dots span {
  width: 5px;
  height: 5px;
  border-radius: 50%;
  background: currentColor;
  animation: case-chat-bounce 0.6s ease-in-out infinite;
}

.case-chat-typing-dots span:nth-child(2) { animation-delay: 0.1s; }
.case-chat-typing-dots span:nth-child(3) { animation-delay: 0.2s; }

@keyframes case-chat-bounce {
  0%, 100% { transform: translateY(0); }
  50% { transform: translateY(-3px); }
}

/* New message notification on specialist FAB */
.case-chat-fab-has-new {
  position: relative;
  animation: case-chat-pulse 2s ease-in-out infinite;
}

.case-chat-fab-badge {
  position: absolute;
  top: -4px;
  right: -4px;
  min-width: 20px;
  height: 20px;
  padding: 0 6px;
  background: #dc2626;
  color: white;
  font-size: 0.75rem;
  font-weight: 700;
  border-radius: 10px;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(220, 38, 38, 0.5);
}

@keyframes case-chat-pulse {
  0%, 100% { box-shadow: 0 4px 20px rgba(37, 99, 235, 0.3); }
  50% { box-shadow: 0 4px 24px rgba(37, 99, 235, 0.5), 0 0 0 4px rgba(37, 99, 235, 0.2); }
}

@media (max-width: 639px) {
  .case-chat-widget {
    bottom: calc(5.5rem + env(safe-area-inset-bottom, 0px));
    right: max(1.25rem, env(safe-area-inset-right, 0px) + 0.5rem);
  }

  .ai-chat-panel {
    width: min(380px, calc(100vw - 1.5rem));
    max-height: 80vh;
    bottom: calc(100% + 0.75rem);
  }

  .ai-chat-header {
    padding: 1rem 1rem 1rem 1.25rem;
  }

  .ai-chat-close {
    min-width: 48px;
    min-height: 48px;
  }
}

@media (max-width: 439px) {
  .ai-chat-panel {
    width: calc(100vw - 1.5rem);
    max-height: 85vh;
  }

  .ai-chat-fab-label {
    display: none;
  }

  .ai-chat-fab {
    padding: 0.75rem 1rem;
    border-radius: 50%;
    min-width: 48px;
    min-height: 48px;
    align-items: center;
    justify-content: center;
  }
}

/* Sticky CTA bar: above specialist FAB on phone, comfortable tap target */
@media (max-width: 639px) {
  .sticky-cta-bar {
    padding: 0.875rem 1rem;
    min-height: 52px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    padding-bottom: max(0.875rem, env(safe-area-inset-bottom, 0px) + 0.5rem);
  }

  .sticky-cta-bar a {
    min-height: 48px;
    display: inline-flex;
    align-items: center;
    padding: 0 1.25rem;
    -webkit-tap-highlight-color: transparent;
    font-size: 1rem;
    font-weight: 600;
  }
}

@media (min-width: 768px) and (max-width: 1023px) {
  .sticky-cta-bar {
    padding: 0.75rem 1.25rem;
  }
}
