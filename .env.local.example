# Supabase (get from Dashboard → Project Settings → API)
# Anon key is a long JWT starting with eyJ... — do NOT use a Stripe key here
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# Stripe
STRIPE_SECRET_KEY=sk_test_...
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Base URL for redirects and SEO (canonical, sitemap)
BASE_URL=http://localhost:3000
# Optional: full path to your project folder so "Edit this page" on visa pages can open the file in Cursor/VS Code (e.g. C:/Users/you/Desktop/portugal-immigration-app)
# NEXT_PUBLIC_EDITOR_ROOT=C:/Users/mrbra/Desktop/portugal-immigration-app
# Public base URL for production (e.g. https://winit.com) — used for canonical links and sitemap
# NEXT_PUBLIC_BASE_URL=https://yourdomain.com

# AI chat assistant — use one of the following (widget shows "not configured" if neither is set)
# Google Gemini (recommended): https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key
# Or OpenAI: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Contact form emails (Resend: https://resend.com — free tier available)
RESEND_API_KEY=re_...
# Who receives form submissions. Without a verified domain, Resend only allows sending to your Resend account email — set this to that email (e.g. hassan_idris@icloud.com). After verifying at resend.com/domains, set to idris@winit.biz.
# CONTACT_TO_EMAIL=hassan_idris@icloud.com
# CONTACT_TO_EMAIL=idris@winit.biz
# Optional: custom "from" address once your domain is verified (default: WinIT Contact <onboarding@resend.dev>)
# RESEND_FROM_EMAIL=WinIT <contact@winit.biz>
