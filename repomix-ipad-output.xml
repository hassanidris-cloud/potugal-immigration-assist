              </div>

              <div>
                <label htmlFor="visaType" style={{ display: 'block', marginBottom: '0.5rem', fontWeight: '600', color: '#1e293b' }}>Which Visa Type Do You Need? ðŸ‡µðŸ‡¹</label>
                <select
                  id="visaType"
                  value={visaType}
                  onChange={(e) => setVisaType(e.target.value)}
                  style={{ width: '100%', padding: '0.75rem', borderRadius: '8px', border: '2px solid #e2e8f0', fontSize: '1rem', background: 'white' }}
                >
                  <optgroup label="Short Stay (Up to 90 days)">
